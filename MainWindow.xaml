<Window x:Class="CrownDripAutoclicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrownDrip Autoclicker" Height="340" Width="520"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize">
    <Border Background="#0F0F17" CornerRadius="12" MouseDown="TitleBar_MouseDown">
        <Border.Effect><DropShadowEffect Color="#000" BlurRadius="24" ShadowDepth="0" Opacity=".7"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#09090F">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Background="#5B21B6" Width="4" HorizontalAlignment="Left" CornerRadius="2,0,0,2"/>
                <TextBlock Text="CrownDrip Autoclicker" Foreground="#E2E8F0" FontSize="13" FontWeight="Medium"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="─" Foreground="#64748B" Background="Transparent" BorderThickness="0"
                            Width="36" Height="38" FontSize="14" Click="Minimize_Click" Cursor="Hand"/>
                    <Button Content="✕" Foreground="#64748B" Background="Transparent" BorderThickness="0"
                            Width="36" Height="38" FontSize="12" Click="Close_Click" Cursor="Hand">
                        <Button.Style><Style TargetType="Button">
                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Width="36" Height="38">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="#FCA5A5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate></Setter.Value></Setter>
                        </Style></Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <!-- Left: controls -->
                <StackPanel Grid.Column="0">

                    <!-- CPS row -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="CPS" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CpsText" Grid.Column="1" Text="20" Foreground="#A78BFA" FontSize="18" FontWeight="Bold"/>
                    </Grid>
                    <Slider x:Name="CpsSlider" Minimum="1" Maximum="100" Value="20" Margin="0,0,0,6" Height="18">
                        <Slider.Style><Style TargetType="Slider">
                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Slider">
                                <Grid Height="18">
                                    <Border Height="3" CornerRadius="2" Background="#1E1E30" VerticalAlignment="Center"/>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton><RepeatButton Command="Slider.DecreaseLarge"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="3" CornerRadius="2" Background="#7C3AED"/></ControlTemplate></RepeatButton.Template></RepeatButton></Track.DecreaseRepeatButton>
                                        <Track.Thumb><Thumb><Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Width="14" Height="14" Fill="#A78BFA"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb>
                                        <Track.IncreaseRepeatButton><RepeatButton Command="Slider.IncreaseLarge"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="3" Background="Transparent"/></ControlTemplate></RepeatButton.Template></RepeatButton></Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate></Setter.Value></Setter>
                        </Style></Slider.Style>
                    </Slider>
                    <CheckBox x:Name="Randomize" Content="Randomize ±3 CPS" Foreground="#64748B" FontSize="12" Margin="0,0,0,14"/>

                    <!-- Delay row -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <CheckBox x:Name="UseDelay" Content="Fixed delay" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="DelayBox" Text="50" Width="52" Height="26" IsEnabled="False"
                                     Background="#1A1A28" Foreground="#E2E8F0" BorderBrush="#2D2D45"
                                     BorderThickness="1" Padding="6,3" FontSize="12">
                                <TextBox.Style><Style TargetType="TextBox">
                                    <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate></Setter.Value></Setter>
                                </Style></TextBox.Style>
                            </TextBox>
                            <TextBlock Text=" ms" Foreground="#475569" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separator -->
                    <Border Height="1" Background="#1E1E30" Margin="0,6,0,10"/>

                    <!-- Hotkey -->
                    <TextBlock Text="HOTKEY" Foreground="#374151" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Button x:Name="HotkeyBtn" Content="Num 0" Click="HotkeyBtn_Click" Cursor="Hand"
                                Height="30" Padding="10,0" FontSize="12" FontWeight="Medium">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Background" Value="#1A1A28"/>
                                <Setter Property="Foreground" Value="#A78BFA"/>
                                <Setter Property="BorderBrush" Value="#3B1D8A"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#23174A"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate></Setter.Value></Setter>
                            </Style></Button.Style>
                        </Button>
                        <TextBlock x:Name="HotkeyHint" Grid.Column="1"
                                   Text=" · click to rebind" Foreground="#374151" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>

                <!-- Right: status + toggle -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">

                    <Border Background="#0A0A14" CornerRadius="10" Padding="12,10" Margin="0,0,0,12" Width="130">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Ellipse x:Name="Dot" Width="7" Height="7" Fill="#374151" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="StatusText" Text="Idle" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                            <TextBlock x:Name="ClickCount" Text="0 clicks" Foreground="#374151" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="ToggleBtn" Content="START" Height="52" Width="130"
                            FontSize="15" FontWeight="Bold" Click="Toggle_Click" Cursor="Hand">
                        <Button.Style><Style TargetType="Button">
                            <Setter Property="Background" Value="#6D28D9"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#5B21B6"/></Trigger>
                                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#4C1D95"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate></Setter.Value></Setter>
                        </Style></Button.Style>
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
