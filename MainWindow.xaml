<Window x:Class="CrownDripAutoclicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrownDrip Autoclicker" Height="300" Width="422"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize">

    <!-- ═══ OUTER GOLD FRAME ═══ -->
    <Border CornerRadius="14" Padding="1.5">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#7A5C1E" Offset="0.00"/>
                <GradientStop Color="#F0D060" Offset="0.20"/>
                <GradientStop Color="#C8A830" Offset="0.45"/>
                <GradientStop Color="#F5E070" Offset="0.70"/>
                <GradientStop Color="#8B6520" Offset="1.00"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#C8A830" BlurRadius="36" ShadowDepth="0" Opacity="0.50"/>
        </Border.Effect>

        <!-- ═══ WINDOW BODY ═══ -->
        <Border CornerRadius="13" MouseDown="TitleBar_MouseDown" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                    <GradientStop Color="#0C0A01" Offset="0.0"/>
                    <GradientStop Color="#111005" Offset="0.5"/>
                    <GradientStop Color="#090800" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ TITLE BAR ═══ -->
                <Grid Grid.Row="0" ClipToBounds="True">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#100E02" Offset="0"/>
                            <GradientStop Color="#080700" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Top shimmer line -->
                    <Border Height="1" VerticalAlignment="Top" Opacity="0.30">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#F5E070"     Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Bottom gold divider -->
                    <Border Height="1" VerticalAlignment="Bottom">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#9A7820"     Offset="0.15"/>
                                <GradientStop Color="#F0D060"     Offset="0.50"/>
                                <GradientStop Color="#9A7820"     Offset="0.85"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Crown + wordmark -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <!-- Crown glyph with gold glow -->
                        <TextBlock Text="♛" FontSize="17" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#F5E070" Offset="0"/>
                                    <GradientStop Color="#C8A830" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#C8A830" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <!-- CROWNDRIP AUTOCLICKER wordmark -->
                        <TextBlock FontSize="12" FontWeight="Bold" LetterSpacing="3" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8C84A" Offset="0"/>
                                    <GradientStop Color="#F5E070" Offset="0.5"/>
                                    <GradientStop Color="#C8A830" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <Run Text="CROWN"/><Run Text="DRIP" Foreground="#C8A830"/><Run Text="  AUTOCLICKER" FontSize="10" Foreground="#7A6020"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Window buttons -->
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <!-- Minimize -->
                        <Button Content="─" Width="38" Height="46" FontSize="12"
                                Click="Minimize_Click" Cursor="Hand"
                                Foreground="#3A3010" Background="Transparent" BorderThickness="0">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Template"><Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Width="38" Height="46">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A1600"/>
                                                <Setter Property="Foreground" Value="#C8A830"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value></Setter>
                            </Style></Button.Style>
                        </Button>
                        <!-- Close -->
                        <Button Content="✕" Width="38" Height="46" FontSize="11"
                                Click="Close_Click" Cursor="Hand"
                                Foreground="#3A3010" Background="Transparent" BorderThickness="0">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Template"><Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Width="38" Height="46" CornerRadius="0,13,0,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3A0A0A"/>
                                                <Setter Property="Foreground" Value="#FCA5A5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value></Setter>
                            </Style></Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ═══ MAIN CONTENT ═══ -->
                <Grid Grid.Row="1" Margin="24,20,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="112"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── LEFT COLUMN ── -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">

                        <!-- Section label -->
                        <TextBlock Text="CLICK  DELAY" Foreground="#2A2008"
                                   FontSize="7.5" FontWeight="Bold" LetterSpacing="3.5"
                                   Margin="0,0,0,12"/>

                        <!-- Interval row -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Interval" Foreground="#5A4818"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Gold-bordered textbox -->
                                <Border CornerRadius="6" Padding="0" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5A4010" Offset="0"/>
                                            <GradientStop Color="#C8A830" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <TextBox x:Name="DelayBox" Text="50" Width="58" Height="28"
                                             Background="#0C0A01" Foreground="#E8C84A"
                                             BorderThickness="0" Padding="8,3"
                                             FontSize="12" FontWeight="Medium"
                                             CaretBrush="#C8A830" SelectionBrush="#C8A83050"
                                             VerticalContentAlignment="Center">
                                        <TextBox.Style><Style TargetType="TextBox">
                                            <Setter Property="Template"><Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="5">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Margin="{TemplateBinding Padding}"
                                                                      VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value></Setter>
                                        </Style></TextBox.Style>
                                    </TextBox>
                                </Border>
                                <TextBlock Text=" ms" Foreground="#4A3C10"
                                           FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Jitter checkbox -->
                        <CheckBox x:Name="Randomize" Foreground="#4A3C10" FontSize="11" Margin="0,10,0,0">
                            <CheckBox.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Jitter  " Foreground="#4A3C10" FontSize="11"/>
                                    <TextBlock Text="± 10 ms" Foreground="#7A6020" FontSize="11"/>
                                </StackPanel>
                            </CheckBox.Content>
                            <CheckBox.Style><Style TargetType="CheckBox">
                                <Setter Property="Template"><Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="15" Height="15" CornerRadius="4"
                                                    BorderThickness="1" Background="#0C0A01"
                                                    Margin="0,0,8,0">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#5A4010" Offset="0"/>
                                                        <GradientStop Color="#C8A830" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <TextBlock x:Name="Chk" Text="✓" FontSize="10"
                                                           Foreground="#C8A830" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value></Setter>
                            </Style></CheckBox.Style>
                        </CheckBox>

                        <!-- Gold divider -->
                        <Border Height="1" Margin="0,16,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3A2C08" Offset="0"/>
                                    <GradientStop Color="#C8A83050" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Hotkey section -->
                        <TextBlock Text="HOTKEY" Foreground="#2A2008"
                                   FontSize="7.5" FontWeight="Bold" LetterSpacing="3.5"
                                   Margin="0,0,0,9"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="HotkeyBtn" Content="Num 0"
                                    Click="HotkeyBtn_Click" Cursor="Hand"
                                    Height="28" Padding="12,0"
                                    FontSize="11" FontWeight="Bold" Foreground="#C8A830">
                                <Button.Style><Style TargetType="Button">
                                    <Setter Property="Template"><Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="7"
                                                    Background="#0C0A01" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#5A4010" Offset="0"/>
                                                        <GradientStop Color="#C8A830" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A1600"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value></Setter>
                                </Style></Button.Style>
                            </Button>
                            <TextBlock x:Name="HotkeyHint" Text="  · rebind"
                                       Foreground="#2A2008" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- ── RIGHT COLUMN ── -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <!-- Status pill -->
                        <Border CornerRadius="9" Width="112" Padding="0,9" Margin="0,0,0,12"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0E0C02" Offset="0"/>
                                    <GradientStop Color="#080700" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3A2C08" Offset="0"/>
                                    <GradientStop Color="#6A5018" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse x:Name="Dot" Width="6" Height="6" Fill="#2A2008"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock x:Name="StatusText" Text="IDLE"
                                           Foreground="#3A3010" FontSize="10"
                                           FontWeight="Bold" LetterSpacing="2"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- START / STOP button -->
                        <Button x:Name="ToggleBtn" Content="START"
                                Height="52" Width="112"
                                FontSize="13" FontWeight="Bold" LetterSpacing="2"
                                Foreground="#0A0900"
                                Click="Toggle_Click" Cursor="Hand">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#F0D060" Offset="0.0"/>
                                    <GradientStop Color="#C8A830" Offset="0.5"/>
                                    <GradientStop Color="#A07820" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Template"><Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="11" Background="{TemplateBinding Background}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#C8A830" BlurRadius="14"
                                                                  ShadowDepth="0" Opacity="0.45"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#F0D060" BlurRadius="24"
                                                                          ShadowDepth="0" Opacity="0.65"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#C8A830" BlurRadius="6"
                                                                          ShadowDepth="0" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value></Setter>
                            </Style></Button.Style>
                        </Button>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
