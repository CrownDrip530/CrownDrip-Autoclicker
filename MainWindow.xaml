<Window x:Class="CrownDripAutoclicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrownDrip Autoclicker"
        Height="560"
        Width="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#0B0B10">

    <Grid>

        <Border Margin="16"
                CornerRadius="20"
                Background="#16161F">

            <Grid>

                <!-- CUSTOM TITLE BAR -->
                <Grid Height="45"
                      VerticalAlignment="Top"
                      Background="#12121A">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="  CrownDrip Autoclicker"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="Bold"
                               MouseDown="DragWindow"/>

                    <StackPanel Orientation="Horizontal"
                                Grid.Column="1">

                        <Button Content="—"
                                Width="40"
                                Background="Transparent"
                                Foreground="White"
                                Click="Minimize_Click"/>

                        <Button Content="▢"
                                Width="40"
                                Background="Transparent"
                                Foreground="White"
                                Click="Fullscreen_Click"/>

                        <Button Content="✕"
                                Width="40"
                                Background="Transparent"
                                Foreground="#FF4C4C"
                                Click="Close_Click"/>

                    </StackPanel>

                </Grid>

                <!-- MAIN CONTENT -->
                <Grid Margin="10,55,10,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel Margin="20">

                        <TextBlock Text="CrownDrip Autoclicker"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Neon Click Engine"
                                   Foreground="#888"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="CPS Mode"
                                   Foreground="White"/>

                        <Slider x:Name="CpsSlider"
                                Minimum="1"
                                Maximum="80"
                                Value="20"
                                Margin="0,10,0,5"/>

                        <TextBlock x:Name="CpsText"
                                   Text="20 CPS"
                                   Foreground="#A855F7"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <CheckBox x:Name="Randomize"
                                  Content="Random CPS"
                                  Foreground="White"
                                  Margin="0,10,0,0"/>

                        <TextBlock Text="Delay Mode (ms)"
                                   Foreground="White"
                                   Margin="0,20,0,5"/>

                        <TextBox x:Name="DelayBox"
                                 Text="50"
                                 Height="35"
                                 Background="#1E1E2A"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="8"/>

                        <CheckBox x:Name="UseDelayMode"
                                  Content="Use Delay instead of CPS"
                                  Foreground="White"
                                  Margin="0,10,0,0"/>

                    </StackPanel>

                    <!-- RIGHT -->
                    <StackPanel Grid.Column="1" Margin="10">

                        <Border x:Name="GlowBorder"
                                CornerRadius="20"
                                Padding="3"
                                Margin="10">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="Red" Offset="0"/>
                                    <GradientStop Color="Yellow" Offset="0.2"/>
                                    <GradientStop Color="Lime" Offset="0.4"/>
                                    <GradientStop Color="Cyan" Offset="0.6"/>
                                    <GradientStop Color="Blue" Offset="0.8"/>
                                    <GradientStop Color="Magenta" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Button x:Name="ToggleButton"
                                    Content="START"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Background="#1E1E2A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Height="85"/>

                        </Border>

                        <TextBlock x:Name="StatusText"
                                   Text="Idle"
                                   Foreground="#7CFF7C"
                                   FontSize="20"
                                   Margin="20"/>

                        <TextBlock x:Name="ClickCount"
                                   Text="0 clicks"
                                   Foreground="#AAA"
                                   Margin="20,0,0,0"/>

                        <TextBlock Text="Hotkey: F6"
                                   Foreground="#666"
                                   Margin="20,30,0,0"/>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>
